{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k0rdent.local/docs/agent-learning/schemas/failure-log-entry.schema.json",
  "title": "Failure Log Entry",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "source",
    "query",
    "matched_route",
    "confidence",
    "acceptable",
    "expected_routes",
    "scope_violation",
    "run_id"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "source": { "type": "string", "enum": ["shadow", "golden", "runtime"] },
    "query": { "type": "string" },
    "topic": { "type": "string" },
    "matched_route": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0 },
    "acceptable": { "type": "boolean" },
    "expected_routes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_violation": { "type": "boolean" },
    "failure_reason": { "type": "string" },
    "route_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route_id", "score"],
        "properties": {
          "route_id": { "type": "string" },
          "score": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "run_id": { "type": "string" },
    "commit_sha": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
