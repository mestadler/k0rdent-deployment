# Required context
KUBECONFIG_CONTEXT=dev-cluster

# Enable flags
ENABLE_KCM=true
ENABLE_KSM=true
ENABLE_K0RDENT_UI=true

# Namespaces
KCM_NAMESPACE=kcm-system
KSM_NAMESPACE=ksm-system
K0RDENT_UI_NAMESPACE=k0rdent-ui

# Release names
KCM_RELEASE=kcm
KSM_RELEASE=ksm
K0RDENT_UI_RELEASE=k0rdent-ui

# Deployment names (override if chart naming differs)
KCM_DEPLOYMENT=kcm-controller-manager
KSM_DEPLOYMENT=ksm-controller-manager
K0RDENT_UI_DEPLOYMENT=k0rdent-ui

# OCI chart references
KCM_CHART=oci://ghcr.io/k0rdent/kcm/charts/kcm
KSM_CHART=oci://ghcr.io/k0rdent/ksm/charts/ksm
K0RDENT_UI_CHART=oci://ghcr.io/k0rdent/k0rdent-ui/k0rdent-ui

# Chart versions
KCM_VERSION=1.8.0
KSM_VERSION=1.8.0
K0RDENT_UI_VERSION=1.2.0

# Optional chart pull secret check
HELM_REGISTRY_HOST=ghcr.io

# Paths
VALUES_DIR=environments/dev/values
LOCK_FILE=environments/dev/artifact-lock.yaml
